@using Microsoft.AspNetCore.Components.Routing
@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudText Typo="Typo.h6">Library Online</MudText>
    </MudAppBar>

    <MudDrawer Open="true" ClipMode="DrawerClipMode.Always" Variant="DrawerVariant.Mini">
        <MudNavMenu>
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
            <MudNavLink Href="/books" Icon="@Icons.Material.Filled.MenuBook">Books</MudNavLink>
            <MudNavLink Href="/authors" Icon="@Icons.Material.Filled.Person">Authors</MudNavLink>
            <MudNavLink Href="/categories" Icon="@Icons.Material.Filled.Category">Categories</MudNavLink>
            <MudNavLink Href="/members" Icon="@Icons.Material.Filled.Groups">Members</MudNavLink>
            <MudNavLink Href="/loans" Icon="@Icons.Material.Filled.AssignmentReturn">Loans</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="pa-4">
        @Body
    </MudMainContent>
</MudLayout>