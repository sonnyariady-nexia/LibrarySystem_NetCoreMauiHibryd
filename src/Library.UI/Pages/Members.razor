@page "/members"
@using Library.UI.Models
@using Microsoft.JSInterop
@implements IDisposable
@inject ApiClient Api
@inject IJSRuntime JS
@inject MudBlazor.IDialogService DialogService

<MudText Typo="Typo.h4" Class="mb-3">Members</MudText>

@if (isLoading || isExporting)
{
    <MudOverlay Visible="true" DarkBackground="true" AutoClose="false" ZIndex="2000">
        <MudPaper Class="pa-6 d-flex flex-column align-center justify-center">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <MudText Class="mt-3">@(isExporting ? "Exporting Excel..." : "Loading data...")</MudText>
        </MudPaper>
    </MudOverlay>
}

<MudPaper Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="12" md="4">
            <MudTextField T="string" Value="@search" ValueChanged="@(async v => await OnSearchChanged(v))" Label="Global Search" Placeholder="Code / Full Name / Email / Phone" Immediate="true" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
        </MudItem>
        <MudItem xs="12" md="2">
            <MudTextField T="string" Value="@codeFilter" ValueChanged="@(async v => await OnCodeFilterChanged(v))" Label="Code Filter" Placeholder="Contains code" Immediate="true" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudTextField T="string" Value="@fullNameFilter" ValueChanged="@(async v => await OnFullNameFilterChanged(v))" Label="Full Name Filter" Placeholder="Contains full name" Immediate="true" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudSelect T="bool?" @bind-Value="isActiveFilter" Label="Active Status">
                <MudSelectItem T="bool?" Value="@((bool?)null)">All</MudSelectItem>
                <MudSelectItem T="bool?" Value="@((bool?)true)">Active</MudSelectItem>
                <MudSelectItem T="bool?" Value="@((bool?)false)">Inactive</MudSelectItem>
            </MudSelect>
        </MudItem>
    </MudGrid>

    <div class="d-flex flex-wrap gap-2 mt-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenCreateAsync">Add Member</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="SearchNowAsync">Search</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ResetFiltersAsync">Reset</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Success" OnClick="ExportExcelAsync">Export Excel</MudButton>
    </div>
</MudPaper>

<MudPaper Class="pa-4 mb-3">
    <div class="d-flex flex-wrap gap-2 align-center">
        <MudSelect T="string" @bind-Value="sortBy" Label="Sort By" Style="width:180px">
            <MudSelectItem T="string" Value="@("Code")">Code</MudSelectItem>
            <MudSelectItem T="string" Value="@("FullName")">Full Name</MudSelectItem>
            <MudSelectItem T="string" Value="@("CreatedAt")">Created At</MudSelectItem>
        </MudSelect>
        <MudSelect T="bool" @bind-Value="sortDesc" Label="Sort Direction" Style="width:180px">
            <MudSelectItem T="bool" Value="@false">Ascending</MudSelectItem>
            <MudSelectItem T="bool" Value="@true">Descending</MudSelectItem>
        </MudSelect>
    </div>
</MudPaper>

<MudPaper Class="pa-2">
    <MudTable Items="members" Hover="true" Dense="true" Loading="isLoading">
        <HeaderContent>
            <MudTh>Code</MudTh>
            <MudTh>Full Name</MudTh>
            <MudTh>Email</MudTh>
            <MudTh>Phone</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Created At</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Code</MudTd>
            <MudTd>@context.FullName</MudTd>
            <MudTd>@(string.IsNullOrWhiteSpace(context.Email) ? "-" : context.Email)</MudTd>
            <MudTd>@(string.IsNullOrWhiteSpace(context.Phone) ? "-" : context.Phone)</MudTd>
            <MudTd>
                @if (context.IsActive)
                {
                    <MudChip T="bool" Color="Color.Success">Active</MudChip>
                }
                else
                {
                    <MudChip T="bool" Color="Color.Error">Inactive</MudChip>
                }
            </MudTd>
            <MudTd>@context.CreatedAt.ToString("dd MMM yyyy HH:mm")</MudTd>
            <MudTd>
                <MudButton Size="Size.Small" OnClick="@(() => OpenEditAsync(context))">Edit</MudButton>
                <MudButton Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Id))">Delete</MudButton>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent><MudText Class="pa-4">No members found.</MudText></NoRecordsContent>
    </MudTable>

    <div class="d-flex justify-space-between align-center pa-3">
        <MudText>Total: @totalCount item(s)</MudText>
        <div class="d-flex align-center gap-2">
            <MudSelect T="int" @bind-Value="_pageSize" Label="Page Size" Style="width:120px">
                <MudSelectItem T="int" Value="10">10</MudSelectItem>
                <MudSelectItem T="int" Value="20">20</MudSelectItem>
                <MudSelectItem T="int" Value="50">50</MudSelectItem>
                <MudSelectItem T="int" Value="100">100</MudSelectItem>
            </MudSelect>
            <MudPagination Count="@(totalPages == 0 ? 1 : totalPages)" Page="@_page" PageChanged="OnPageChanged" Color="Color.Primary" Variant="Variant.Outlined" />
        </div>
    </div>
</MudPaper>

@code {
    private List<MemberVm> members = new();
    private string? search;
    private string? codeFilter;
    private string? fullNameFilter;
    private bool? isActiveFilter;
    private bool isLoading;
    private bool isExporting;
    private bool _loaded;
    private bool _disposed;
    private int _page = 1;
    private int _pageSize = 10;
    private int totalPages = 1;
    private long totalCount;
    private string? sortBy = "Code";
    private bool sortDesc;
    private CancellationTokenSource? _debounceCts;

    protected override async Task OnInitializedAsync() { if (_loaded || _disposed) return; _loaded = true; await LoadDataAsync(); }
    private Dictionary<string, string?> BuildFilters() { var filters = new Dictionary<string, string?>(); if (!string.IsNullOrWhiteSpace(codeFilter)) filters["Code"] = codeFilter; if (!string.IsNullOrWhiteSpace(fullNameFilter)) filters["FullName"] = fullNameFilter; if (isActiveFilter.HasValue) filters["IsActive"] = isActiveFilter.Value.ToString(); return filters; }
    private async Task LoadDataAsync() { if (_disposed) return; try { isLoading = true; var result = await Api.SearchAsync<MemberVm>("members", search, _page, _pageSize, sortBy, sortDesc, BuildFilters()); if (_disposed) return; members = result.Items.ToList(); totalCount = result.TotalCount; totalPages = result.TotalPages; _page = result.PageNumber; } finally { if (!_disposed) isLoading = false; } }
    private async Task OpenCreateAsync() { var dialog = await DialogService.ShowAsync<MemberForm>("Add Member", new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true }); var result = await dialog.Result; if (!result.Canceled) await LoadDataAsync(); }
    private async Task OpenEditAsync(MemberVm item) { var dialog = await DialogService.ShowAsync<MemberForm>("Edit Member", new DialogParameters { { nameof(MemberForm.Model), item } }, new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true }); var result = await dialog.Result; if (!result.Canceled) await LoadDataAsync(); }
    private async Task SearchNowAsync() { _page = 1; await LoadDataAsync(); }
    private async Task ResetFiltersAsync() { search = codeFilter = fullNameFilter = null; isActiveFilter = null; _page = 1; sortBy = "Code"; sortDesc = false; await LoadDataAsync(); }
    private async Task DeleteAsync(int id) { if (_disposed) return; isLoading = true; await Api.DeleteAsync("members", id); if (_disposed) return; await LoadDataAsync(); }
    private async Task ExportExcelAsync() { if (_disposed) return; try { isExporting = true; var file = await Api.ExportExcelAsync("members", new ExcelExportRequest(search, BuildFilters(), sortBy, sortDesc, new Dictionary<string, string> { ["Code"] = "Code", ["FullName"] = "Full Name", ["Email"] = "Email", ["Phone"] = "Phone", ["Address"] = "Address", ["IsActive"] = "Active", ["CreatedAt"] = "Created At" }, "Members", $"Members_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx")); if (_disposed) return; await JS.InvokeVoidAsync("downloadFileFromBytes", file.FileName, Convert.ToBase64String(file.Bytes), file.ContentType); } finally { if (!_disposed) isExporting = false; } }
    private async Task DebounceReloadAsync() { if (_disposed) return; _debounceCts?.Cancel(); _debounceCts = new CancellationTokenSource(); var token = _debounceCts.Token; try { await Task.Delay(500, token); if (_disposed || token.IsCancellationRequested) return; _page = 1; await InvokeAsync(LoadDataAsync); } catch (TaskCanceledException) { } }
    private async Task OnSearchChanged(string? value) { search = value; await DebounceReloadAsync(); }
    private async Task OnCodeFilterChanged(string? value) { codeFilter = value; await DebounceReloadAsync(); }
    private async Task OnFullNameFilterChanged(string? value) { fullNameFilter = value; await DebounceReloadAsync(); }
    private async Task OnPageChanged(int page) { _page = page; await LoadDataAsync(); }
    public void Dispose() { _disposed = true; _debounceCts?.Cancel(); _debounceCts?.Dispose(); }
}
