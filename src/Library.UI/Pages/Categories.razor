@page "/categories"
@using Library.UI.Models
@using Microsoft.JSInterop
@implements IDisposable
@inject ApiClient Api
@inject IJSRuntime JS
@inject MudBlazor.IDialogService DialogService

<MudText Typo="Typo.h4" Class="mb-3">Categories</MudText>

@if (isLoading || isExporting)
{
    <MudOverlay Visible="true" DarkBackground="true" AutoClose="false" ZIndex="2000">
        <MudPaper Class="pa-6 d-flex flex-column align-center justify-center">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <MudText Class="mt-3">@(isExporting ? "Exporting Excel..." : "Loading data...")</MudText>
        </MudPaper>
    </MudOverlay>
}

<MudPaper Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="12" md="6">
            <MudTextField T="string" Value="@search" ValueChanged="@(async v => await OnSearchChanged(v))" Label="Global Search" Placeholder="Name / Description" Immediate="true" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudTextField T="string" Value="@nameFilter" ValueChanged="@(async v => await OnNameFilterChanged(v))" Label="Name Filter" Placeholder="Contains name" Immediate="true" />
        </MudItem>
        <MudItem xs="12" md="3">
            <MudTextField T="string" Value="@descriptionFilter" ValueChanged="@(async v => await OnDescriptionFilterChanged(v))" Label="Description Filter" Placeholder="Contains description" Immediate="true" />
        </MudItem>
    </MudGrid>

    <div class="d-flex flex-wrap gap-2 mt-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenCreateAsync">Add Category</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Secondary" OnClick="SearchNowAsync">Search</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="ResetFiltersAsync">Reset</MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Success" OnClick="ExportExcelAsync">Export Excel</MudButton>
    </div>
</MudPaper>

<MudPaper Class="pa-4 mb-3">
    <div class="d-flex flex-wrap gap-2 align-center">
        <MudSelect T="string" @bind-Value="sortBy" Label="Sort By" Style="width:180px">
            <MudSelectItem T="string" Value="@("Name")">Name</MudSelectItem>
            <MudSelectItem T="string" Value="@("CreatedAt")">Created At</MudSelectItem>
        </MudSelect>
        <MudSelect T="bool" @bind-Value="sortDesc" Label="Sort Direction" Style="width:180px">
            <MudSelectItem T="bool" Value="@false">Ascending</MudSelectItem>
            <MudSelectItem T="bool" Value="@true">Descending</MudSelectItem>
        </MudSelect>
    </div>
</MudPaper>

<MudPaper Class="pa-2">
    <MudTable Items="categories" Hover="true" Dense="true" Loading="isLoading">
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Description</MudTh>
            <MudTh>Created At</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd>@(string.IsNullOrWhiteSpace(context.Description) ? "-" : context.Description)</MudTd>
            <MudTd>@context.CreatedAt.ToString("dd MMM yyyy HH:mm")</MudTd>
            <MudTd>
                <MudButton Size="Size.Small" OnClick="@(() => OpenEditAsync(context))">Edit</MudButton>
                <MudButton Size="Size.Small" Color="Color.Error" OnClick="@(() => DeleteAsync(context.Id))">Delete</MudButton>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent><MudText Class="pa-4">No categories found.</MudText></NoRecordsContent>
    </MudTable>

    <div class="d-flex justify-space-between align-center pa-3">
        <MudText>Total: @totalCount item(s)</MudText>
        <div class="d-flex align-center gap-2">
            <MudSelect T="int" @bind-Value="_pageSize" Label="Page Size" Style="width:120px">
                <MudSelectItem T="int" Value="10">10</MudSelectItem>
                <MudSelectItem T="int" Value="20">20</MudSelectItem>
                <MudSelectItem T="int" Value="50">50</MudSelectItem>
                <MudSelectItem T="int" Value="100">100</MudSelectItem>
            </MudSelect>
            <MudPagination Count="@(totalPages == 0 ? 1 : totalPages)" Page="@_page" PageChanged="OnPageChanged" Color="Color.Primary" Variant="Variant.Outlined" />
        </div>
    </div>
</MudPaper>

@code {
    private List<CategoryVm> categories = new();
    private string? search;
    private string? nameFilter;
    private string? descriptionFilter;
    private bool isLoading;
    private bool isExporting;
    private bool _loaded;
    private bool _disposed;
    private int _page = 1;
    private int _pageSize = 10;
    private int totalPages = 1;
    private long totalCount;
    private string? sortBy = "Name";
    private bool sortDesc;
    private CancellationTokenSource? _debounceCts;

    protected override async Task OnInitializedAsync() { if (_loaded || _disposed) return; _loaded = true; await LoadDataAsync(); }
    private Dictionary<string, string?> BuildFilters() { var filters = new Dictionary<string, string?>(); if (!string.IsNullOrWhiteSpace(nameFilter)) filters["Name"] = nameFilter; if (!string.IsNullOrWhiteSpace(descriptionFilter)) filters["Description"] = descriptionFilter; return filters; }
    private async Task LoadDataAsync() { if (_disposed) return; try { isLoading = true; var result = await Api.SearchAsync<CategoryVm>("categories", search, _page, _pageSize, sortBy, sortDesc, BuildFilters()); if (_disposed) return; categories = result.Items.ToList(); totalCount = result.TotalCount; totalPages = result.TotalPages; _page = result.PageNumber; } finally { if (!_disposed) isLoading = false; } }
    private async Task OpenCreateAsync() { var dialog = await DialogService.ShowAsync<CategoryForm>("Add Category", new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true }); var result = await dialog.Result; if (!result.Canceled) await LoadDataAsync(); }
    private async Task OpenEditAsync(CategoryVm item) { var dialog = await DialogService.ShowAsync<CategoryForm>("Edit Category", new DialogParameters { { nameof(CategoryForm.Model), item } }, new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true }); var result = await dialog.Result; if (!result.Canceled) await LoadDataAsync(); }
    private async Task SearchNowAsync() { _page = 1; await LoadDataAsync(); }
    private async Task ResetFiltersAsync() { search = nameFilter = descriptionFilter = null; _page = 1; sortBy = "Name"; sortDesc = false; await LoadDataAsync(); }
    private async Task DeleteAsync(int id) { if (_disposed) return; isLoading = true; await Api.DeleteAsync("categories", id); if (_disposed) return; await LoadDataAsync(); }
    private async Task ExportExcelAsync() { if (_disposed) return; try { isExporting = true; var file = await Api.ExportExcelAsync("categories", new ExcelExportRequest(search, BuildFilters(), sortBy, sortDesc, new Dictionary<string, string> { ["Name"] = "Name", ["Description"] = "Description", ["CreatedAt"] = "Created At" }, "Categories", $"Categories_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx")); if (_disposed) return; await JS.InvokeVoidAsync("downloadFileFromBytes", file.FileName, Convert.ToBase64String(file.Bytes), file.ContentType); } finally { if (!_disposed) isExporting = false; } }
    private async Task DebounceReloadAsync() { if (_disposed) return; _debounceCts?.Cancel(); _debounceCts = new CancellationTokenSource(); var token = _debounceCts.Token; try { await Task.Delay(500, token); if (_disposed || token.IsCancellationRequested) return; _page = 1; await InvokeAsync(LoadDataAsync); } catch (TaskCanceledException) { } }
    private async Task OnSearchChanged(string? value) { search = value; await DebounceReloadAsync(); }
    private async Task OnNameFilterChanged(string? value) { nameFilter = value; await DebounceReloadAsync(); }
    private async Task OnDescriptionFilterChanged(string? value) { descriptionFilter = value; await DebounceReloadAsync(); }
    private async Task OnPageChanged(int page) { _page = page; await LoadDataAsync(); }
    public void Dispose() { _disposed = true; _debounceCts?.Cancel(); _debounceCts?.Dispose(); }
}
